global
    log /dev/log local0
    log /dev/log local1 notice
    daemon
    maxconn 4000

defaults
    log global
    mode tcp
    option tcplog
    option dontlognull
    timeout connect 10s
    timeout client  1m
    timeout server  1m
    retries 3

frontend kubernetes-api
    bind *:{{ haproxy_frontend_port }}
    default_backend kubernetes-control-plane

backend kubernetes-control-plane
    balance roundrobin
    option tcp-check
{% for host in groups['control_plane'] %}
    server {{ host }} {{ hostvars[host].ansible_host }}:{{ apiserver_bind_port }} check
{% endfor %}
