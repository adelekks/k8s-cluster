apiVersion: kubeadm.k8s.io/v1beta4
kind: JoinConfiguration
discovery:
  bootstrapToken:
    apiServerEndpoint: "{{ kubernetes_control_plane_endpoint }}"
    token: "{{ hostvars[groups['admin'][0]].kubeadm_join_token }}"
    caCertHashes:
      - "{{ hostvars[groups['admin'][0]].kubeadm_ca_cert_hash }}"
controlPlane:
  localAPIEndpoint:
    advertiseAddress: "{{ ansible_host }}"
    bindPort: {{ apiserver_bind_port }}
  certificateKey: "{{ hostvars[groups['admin'][0]].kubeadm_certificate_key }}"
nodeRegistration:
  criSocket: "unix:///run/containerd/containerd.sock"
  kubeletExtraArgs:
    - name: node-ip
      value: "{{ ansible_host }}"
